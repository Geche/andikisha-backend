# ================================
# AndikishaHR - Environment Configuration Template
# ================================
# Copy this file to .env and update with your actual values
# Never commit .env files to version control!

# ================================
# DATABASE CONFIGURATION
# ================================

# Main Database URL (adjust database name per service)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/employee_db"

# Service-Specific Database URLs (if using separate databases)
# EMPLOYEE_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/employee_service_db"
# AUTH_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_service_db"
# PAYROLL_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payroll_service_db"
# COMPLIANCE_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/compliance_service_db"

# ================================
# RABBITMQ CONFIGURATION
# ================================

# RabbitMQ Connection URL
RABBITMQ_URL="amqp://admin:admin@localhost:5672"

# RabbitMQ Queue Configuration (optional overrides)
# RABBITMQ_QUEUE="andikisha_events"
# RABBITMQ_EXCHANGE="andikisha_exchange"

# ================================
# REDIS CONFIGURATION
# ================================

# Redis Connection
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="redis123"

# Redis Database Index (optional, default: 0)
# REDIS_DB=0

# Redis Key Prefix (optional)
# REDIS_PREFIX="andikisha:"

# ================================
# SERVICE PORTS
# ================================

# HTTP Server Port
PORT=3001

# gRPC Server Port
GRPC_PORT=5001

# Service-Specific Ports (if running multiple services locally)
# API_GATEWAY_PORT=3000
# EMPLOYEE_SERVICE_PORT=3001
# AUTH_SERVICE_PORT=3002
# PAYROLL_SERVICE_PORT=3003
# COMPLIANCE_SERVICE_PORT=3004

# ================================
# ENVIRONMENT & LOGGING
# ================================

# Application Environment
NODE_ENV=development

# Log Level (debug, info, warn, error)
LOG_LEVEL=debug

# Enable Query Logging
# PRISMA_LOG_QUERIES=true

# ================================
# MINIO (S3-COMPATIBLE STORAGE)
# ================================

# MinIO Server Configuration
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_USE_SSL=false

# MinIO Bucket Names
# MINIO_BUCKET_DOCUMENTS="andikisha-documents"
# MINIO_BUCKET_EMPLOYEE_PHOTOS="andikisha-photos"
# MINIO_BUCKET_PAYSLIPS="andikisha-payslips"

# ================================
# JWT AUTHENTICATION (When Implemented)
# ================================

# JWT Secret Key (generate a strong random string)
# JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT Expiration Times
# JWT_ACCESS_TOKEN_EXPIRATION="15m"
# JWT_REFRESH_TOKEN_EXPIRATION="7d"

# ================================
# MULTI-TENANCY
# ================================

# Default Tenant Configuration
# DEFAULT_TENANT_ID="default"
# DEFAULT_TENANT_NAME="AndikishaHR"

# Tenant Slug Validation
# TENANT_SLUG_REGEX="^[a-z0-9-]{3,50}$"

# ================================
# EXTERNAL API INTEGRATIONS
# ================================

# --- M-PESA Configuration (Kenya Mobile Payments) ---
# MPESA_ENVIRONMENT="sandbox"  # or "production"
# MPESA_CONSUMER_KEY=""
# MPESA_CONSUMER_SECRET=""
# MPESA_SHORTCODE=""
# MPESA_PASSKEY=""
# MPESA_INITIATOR_NAME=""
# MPESA_SECURITY_CREDENTIAL=""
# MPESA_CALLBACK_URL="https://your-domain.com/api/mpesa/callback"

# --- KRA iTax Configuration (Kenya Revenue Authority) ---
# KRA_ITAX_API_URL="https://itax.kra.go.ke/KRA-Portal"
# KRA_ITAX_USERNAME=""
# KRA_ITAX_PASSWORD=""
# KRA_ITAX_PIN=""
# KRA_ITAX_CERTIFICATE_PATH=""

# --- Africa's Talking (SMS Gateway) ---
# AFRICAS_TALKING_API_KEY=""
# AFRICAS_TALKING_USERNAME=""
# AFRICAS_TALKING_SENDER_ID="AndikishaHR"
# AFRICAS_TALKING_ENVIRONMENT="sandbox"  # or "production"

# --- SendGrid (Email Service) ---
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@andikishaHR.com"
# SENDGRID_FROM_NAME="AndikishaHR System"

# --- Other Integrations ---
# SLACK_WEBHOOK_URL=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# ================================
# CORS CONFIGURATION
# ================================

# Allowed Origins for CORS (comma-separated)
# CORS_ORIGINS="http://localhost:3000,http://localhost:4200"

# Allow Credentials
# CORS_CREDENTIALS=true

# ================================
# RATE LIMITING
# ================================

# Rate Limit Configuration
# RATE_LIMIT_TTL=60  # Time window in seconds
# RATE_LIMIT_MAX=100  # Maximum requests per time window

# ================================
# FILE UPLOAD
# ================================

# Maximum File Upload Size (in bytes)
# MAX_FILE_SIZE=5242880  # 5MB

# Allowed File Types (comma-separated)
# ALLOWED_FILE_TYPES="image/jpeg,image/png,application/pdf"

# ================================
# SECURITY
# ================================

# Encryption Key for Sensitive Data
# ENCRYPTION_KEY="your-32-character-encryption-key"

# Session Secret
# SESSION_SECRET="your-session-secret-key"

# CSRF Token Secret
# CSRF_SECRET="your-csrf-secret-key"

# ================================
# MONITORING & APM (Optional)
# ================================

# Sentry Error Tracking
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"

# New Relic APM
# NEW_RELIC_LICENSE_KEY=""
# NEW_RELIC_APP_NAME="AndikishaHR Backend"

# ================================
# FEATURE FLAGS (Optional)
# ================================

# Enable/Disable Features
# FEATURE_EMPLOYEE_SELF_SERVICE=true
# FEATURE_BIOMETRIC_ATTENDANCE=false
# FEATURE_MOBILE_APP=false
# FEATURE_PAYROLL_AUTOMATION=true

# ================================
# DEVELOPMENT TOOLS
# ================================

# Swagger/OpenAPI Documentation
# SWAGGER_ENABLED=true
# SWAGGER_PATH="/api/docs"

# GraphQL Playground (if using GraphQL)
# GRAPHQL_PLAYGROUND=true

# Debug Mode
# DEBUG=true

# ================================
# BACKUP & MAINTENANCE
# ================================

# Backup Configuration
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE="0 2 * * *"  # Cron expression: Daily at 2 AM
# BACKUP_RETENTION_DAYS=30

# Maintenance Mode
# MAINTENANCE_MODE=false
# MAINTENANCE_MESSAGE="System is under maintenance. Please try again later."

# ================================
# NOTES
# ================================
#
# 1. Database URLs: Update the database name for each service
# 2. JWT_SECRET: Generate using: openssl rand -base64 32
# 3. ENCRYPTION_KEY: Must be exactly 32 characters
# 4. M-PESA: Obtain credentials from Safaricom Developer Portal
# 5. KRA iTax: Register at iTax portal for API access
# 6. Africa's Talking: Sign up at africastalking.com
# 7. SendGrid: Get API key from sendgrid.com
#
# For production:
# - Use strong, unique passwords
# - Never use default credentials
# - Enable SSL/TLS for all connections
# - Use environment-specific secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# - Regularly rotate API keys and secrets
