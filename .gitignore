docker/data/
docker/volumes/
docker/*.env

# Docker Compose overrides (local development variations)
docker-compose.override.yml
docker-compose.*.override.yml
docker-compose.local.yml

# RabbitMQ
docker/rabbitmq/definitions.json.backup

# Redis persistence files
dump.rdb
appendonly.aof
*.rdb
*.aof

# MinIO / S3 local storage
.minio/
.minio.sys/
minio-data/

