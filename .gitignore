# ================================
# Database & Prisma
# ================================

# Local database files
*.db
*.db-journal
*.sqlite
*.sqlite3
postgres-data/
pgdata/

# Prisma generated clients (regenerated via prisma generate)
.prisma/
node_modules/.prisma/
services/*/node_modules/.prisma/
**/node_modules/.prisma/

# Prisma migration SQL files (keep folder structure, ignore content)
# This preserves migration history while ignoring actual SQL
**/prisma/migrations/**/migration.sql
services/*/prisma/migrations/**/migration.sql

# Keep migration directories
!**/prisma/migrations/
!**/prisma/migrations/.gitkeep
!services/*/prisma/migrations/.gitkeep

# Database backups
*.backup
*.dump
*.sql.gz

