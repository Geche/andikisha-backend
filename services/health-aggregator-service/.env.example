# Health Aggregator Service Configuration

# Server
PORT=3010
NODE_ENV=development

# Polling Configuration
HEALTH_POLL_INTERVAL=10000        # Default poll interval (ms) - 10 seconds
HEALTH_CHECK_TIMEOUT=5000         # Timeout for health checks (ms) - 5 seconds

# Storage
STORAGE_TYPE=memory               # Options: memory, redis
REDIS_URL=redis://localhost:6379  # Redis URL for persistent storage

# Service URLs (for polling)
API_GATEWAY_URL=http://localhost:3000
AUTH_SERVICE_URL=http://localhost:3002
EMPLOYEE_SERVICE_URL=http://localhost:3001

# Dashboard
DASHBOARD_AUTH_ENABLED=false      # Enable authentication for dashboard
DASHBOARD_REFRESH_INTERVAL=5000   # Dashboard auto-refresh interval (ms)

# Logging
LOG_LEVEL=info                    # Options: error, warn, info, debug
LOG_FILE=andikisha-health.log    # Log file name
L