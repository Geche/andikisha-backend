{
  "name": "@andikisha/health-aggregator-service",
  "version": "1.0.0",
  "description": "Health Aggregator Service - Centralized health monitoring for AndikishaHR",
  "author": "AndikishaHR",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/cache-manager": "^2.2.2",
    "@willsoto/nestjs-prometheus": "^6.0.1",
    "prom-client": "^15.1.0",
    "cache-manager": "^5.4.0",
    "cache-manager-redis-yet": "^5.0.0",
    "axios": "^1.6.7",
    "rxjs": "^7.8.1",
    "reflect-metadata": "^0.2.2",
    "@andikisha/common": "workspace:*",
    "@andikisha/health": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.2",
    "prettier": "^3.4.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
